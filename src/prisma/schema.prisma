datasource db {
  provider = "postgresql"
}

model User {
  id        String           @id @default(cuid())
  username  String?
  password  String?
  email     String?          @unique
  image     String?
  progresses MangaProgress[]
}

model Manga {
  id        String           @id @default(cuid())
  title     String
  coverUrl  String?
  progresses MangaProgress[]
}

model MangaProgress {
  id        String   @id @default(cuid())
  userId    String
  mangaId   String
  page      Int
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  manga     Manga    @relation(fields: [mangaId], references: [id])

  @@unique([userId, mangaId])
}